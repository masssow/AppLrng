{% extends 'base.html.twig' %}
{% block title %}{{ ressource.titre }}{% endblock %}

{% block body %}
{% set statut = ressource.statut.value %}

<main class="p-4 max-w-2xl mx-auto pb-24">

    {# Breadcrumb #}
    <a href="{{ path('app_parcours_show', {'id': ressource.parcours.id}) }}"
       class="text-white/40 text-sm hover:text-white mb-4 inline-block transition">
        ← {{ ressource.parcours.titre }}
    </a>

    {# En-tête #}
    <div class="mb-6">
        <div class="flex items-center gap-2 mb-1">
            <span class="text-xl">
                {% if ressource.type.value == 'VIDEO' %}🎬
                {% elseif ressource.type.value == 'ARTICLE' %}📄
                {% elseif ressource.type.value == 'COURS' %}📖
                {% elseif ressource.type.value == 'PODCAST' %}🎙️
                {% else %}📚{% endif %}
            </span>
            <span class="text-xs text-white/40">{{ ('type.' ~ ressource.type.value)|trans }}</span>
            {% if ressource.dureeEstimeeMinutes %}
            <span class="text-xs text-white/40">· {{ ressource.dureeEstimeeMinutes }} min</span>
            {% endif %}
        </div>
        <h1 class="text-2xl font-bold">{{ ressource.titre }}</h1>
        <span class="inline-block mt-2 text-xs px-2 py-0.5 rounded-full
            {% if statut == 'consolidee' %}bg-green-800/60 text-green-300
            {% elseif statut == 'en_cours' %}bg-blue-800/60 text-blue-300
            {% elseif statut == 'vue' %}bg-purple-800/60 text-purple-300
            {% else %}bg-white/10 text-white/40{% endif %}">
            {{ ('statut.' ~ statut)|trans }}
        </span>
    </div>

    {# ─── ÉTAT A : À FAIRE ─────────────────────────────── #}
    {% if statut == 'a_faire' %}

    {% if ressource.url %}
    <a href="{{ ressource.url }}" target="_blank" rel="noopener"
       class="flex items-center gap-2 text-[#6C63FF] hover:text-[#8b85ff] text-sm mb-5 transition">
        🔗 {{ 'ressource.open_link'|trans }}
    </a>
    {% endif %}

    {% if ressource.pomodorosSuggeres %}
    <div class="bg-white/5 rounded-xl p-4 mb-6 flex items-center gap-3">
        <span class="text-2xl">🍅</span>
        <div>
            <p class="text-sm font-medium">{{ ressource.pomodorosSuggeres }} {{ 'ressource.pomodoros_suggeres'|trans }}</p>
            <p class="text-xs text-white/40">≈ {{ ressource.pomodorosSuggeres * 25 }} min · {{ 'ressource.pomodoro_tip'|trans }}</p>
        </div>
    </div>
    {% endif %}

    <form method="post" action="{{ path('app_ressource_demarrer', {'id': ressource.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('ressource-' ~ ressource.id) }}">
        <button type="submit"
            class="w-full bg-[#6C63FF] hover:bg-[#5a52e0] text-white py-3 rounded-xl font-semibold transition text-sm">
            🍅 {{ 'ressource.start_cta'|trans }}
        </button>
    </form>

    {# ─── ÉTAT B : EN COURS ────────────────────────────── #}
    {% elseif statut == 'en_cours' %}

    {% if ressource.url %}
    <a href="{{ ressource.url }}" target="_blank" rel="noopener"
       class="flex items-center gap-2 text-[#6C63FF] hover:text-[#8b85ff] text-sm mb-5 transition">
        🔗 {{ 'ressource.open_link'|trans }}
    </a>
    {% endif %}

    {# ── Timer Pomodoro AlpineJS ── #}
    <div x-data="pomodoro('{{ ressource.id }}', {{ ressource.pomodorosSuggeres|default(4) }})" x-init="init()" class="mb-6">

        {# EN ATTENTE #}
        <div x-show="sousEtat === 'en_attente'" class="bg-white/5 rounded-2xl p-6 text-center">
            <p class="text-4xl mb-3">🍅</p>
            <p class="text-white/60 text-sm mb-1">{{ ressource.pomodorosSuggeres|default(4) }} × 25 min</p>
            <p class="text-white/30 text-xs mb-5">≈ {{ (ressource.pomodorosSuggeres|default(4)) * 25 }} min au total</p>
            <button @click="demarrer()"
                class="bg-[#6C63FF] hover:bg-[#5a52e0] text-white px-8 py-3 rounded-xl font-semibold transition text-sm">
                🍅 Démarrer
            </button>
        </div>

        {# EN COURS #}
        <div x-show="sousEtat === 'en_cours'" class="bg-blue-900/20 border border-blue-700/30 rounded-2xl p-6 text-center">
            <p class="text-xs text-blue-300/60 uppercase tracking-wider mb-2">Pomodoro <span x-text="pomodoroActuel"></span> / <span x-text="pomodorosTotal"></span></p>
            <p class="text-6xl font-mono font-bold text-blue-300 mb-5" x-text="affichageTemps()"></p>
            <div class="flex gap-3 justify-center">
                <button @click="pause()"
                    class="bg-white/10 hover:bg-white/20 text-white px-5 py-2 rounded-xl text-sm transition">
                    ⏸ Pause
                </button>
                <button @click="arreter()"
                    class="bg-white/5 hover:bg-white/10 text-white/50 px-5 py-2 rounded-xl text-sm transition">
                    ⏹ Arrêter
                </button>
            </div>
        </div>

        {# PAUSE #}
        <div x-show="sousEtat === 'pause'" class="bg-yellow-900/20 border border-yellow-700/30 rounded-2xl p-6 text-center">
            <p class="text-xs text-yellow-300/60 uppercase tracking-wider mb-2">Pause · Pomodoro <span x-text="pomodoroActuel"></span> / <span x-text="pomodorosTotal"></span></p>
            <p class="text-6xl font-mono font-bold text-yellow-300 mb-5" x-text="affichageTemps()"></p>
            <button @click="reprendre()"
                class="bg-[#6C63FF] hover:bg-[#5a52e0] text-white px-8 py-3 rounded-xl font-semibold transition text-sm">
                ▶ Reprendre
            </button>
        </div>

        {# TERMINÉ #}
        <div x-show="sousEtat === 'termine'" class="bg-green-900/20 border border-green-700/30 rounded-2xl p-6 text-center">
            <p class="text-4xl mb-3">✅</p>
            <p class="font-semibold text-green-300 mb-1">Session terminée !</p>
            <p class="text-white/40 text-sm mb-5">{{ ressource.pomodorosSuggeres|default(4) }} pomodoros complétés</p>
            <a href="{{ path('app_consolidation_initier', {'id': ressource.id}) }}"
               class="block bg-[#6C63FF] hover:bg-[#5a52e0] text-white px-8 py-3 rounded-xl font-semibold transition text-sm">
                ✨ Consolider maintenant
            </a>
        </div>

        {# Notes — toujours visibles sauf si terminé #}
        <div x-show="sousEtat !== 'termine'" class="mt-4">
            <label class="block text-xs text-white/40 mb-2 uppercase tracking-wide">📝 Mes notes</label>
            <textarea x-model="notes" @input="sauvegarderNotes()"
                rows="4" placeholder="Notez ce que vous comprenez au fil de la lecture…"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-[#6C63FF] resize-none placeholder-white/20">
            </textarea>
            <p class="text-xs text-white/20 mt-1">Sauvegardé automatiquement</p>
        </div>

        {# CTA Consolider — accessible à tout moment #}
        <div x-show="sousEtat !== 'termine'" class="mt-4">
            <a href="{{ path('app_consolidation_initier', {'id': ressource.id}) }}"
               class="block w-full text-center text-sm text-white/40 hover:text-white/70 py-2 border border-white/10 rounded-xl transition">
                {{ 'ressource.consolidate_now'|trans }}
            </a>
        </div>

    </div>

    {# ─── ÉTAT C : VUE ─────────────────────────────────── #}
    {% elseif statut == 'vue' %}

    {% if sessionEnCours is not null %}
    <div class="bg-yellow-900/20 border border-yellow-700/30 rounded-xl p-4 mb-5 flex items-start gap-3">
        <span class="text-xl">⏳</span>
        <div>
            <p class="text-sm font-medium text-yellow-300">{{ 'ressource.session_active'|trans }}</p>
            <a href="{{ path('app_consolidation_show', {'id': sessionEnCours.id}) }}"
               class="text-xs text-[#6C63FF] hover:text-[#8b85ff] mt-1 inline-block transition">
                {{ 'ressource.voir_session'|trans }} →
            </a>
        </div>
    </div>
    {% else %}
    <div class="bg-white/5 rounded-xl p-4 mb-5 flex items-start gap-3">
        <span class="text-xl">✅</span>
        <p class="text-sm text-white/70">{{ 'ressource.vue_ready'|trans }}</p>
    </div>

    <a href="{{ path('app_consolidation_initier', {'id': ressource.id}) }}"
       class="block w-full bg-[#6C63FF] hover:bg-[#5a52e0] text-white py-3 rounded-xl font-semibold transition text-sm text-center">
        {{ 'ressource.consolidate_now'|trans }}
    </a>
    {% endif %}

    {# ─── ÉTAT D : CONSOLIDÉE ──────────────────────────── #}
    {% elseif statut == 'consolidee' %}

    {% if derniereSession is not null %}
    <div class="bg-green-900/20 border border-green-700/30 rounded-xl p-5 mb-5">
        <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">🎉</span>
            <p class="font-semibold text-green-300">{{ 'ressource.consolidee_label'|trans }}</p>
        </div>

        {# Score moyen calculé depuis les feedbacks #}
        {% set scores = [] %}
        {% for q in derniereSession.questions %}
            {% if q.feedbackScore is not null %}{% set scores = scores|merge([q.feedbackScore]) %}{% endif %}
        {% endfor %}
        {% if derniereSession.exercice is not null and derniereSession.exercice.feedbackScore is not null %}
            {% set scores = scores|merge([derniereSession.exercice.feedbackScore]) %}
        {% endif %}
        {% if scores|length > 0 %}
        {% set scoreTotal = 0 %}
        {% for s in scores %}{% set scoreTotal = scoreTotal + s %}{% endfor %}
        {% set scoreMoyen = (scoreTotal / scores|length)|round(1) %}
        <div class="flex items-center gap-2 mb-4">
            <div class="flex gap-0.5">
                {% for s in 1..5 %}
                <span class="{% if s <= scoreMoyen %}text-yellow-400{% else %}text-white/20{% endif %}">★</span>
                {% endfor %}
            </div>
            <span class="text-sm text-white/60">{{ scoreMoyen }}/5</span>
        </div>
        {% endif %}

        {# Aperçu des feedbacks #}
        {% for q in derniereSession.questions %}
        {% if q.feedbackIa is not null %}
        <div class="bg-white/5 rounded-lg p-3 mb-2">
            <p class="text-xs text-white/40 mb-1">Q{{ q.ordre }}. {{ q.texte|slice(0,80) }}{% if q.texte|length > 80 %}…{% endif %}</p>
            <p class="text-xs text-green-300">{{ q.feedbackIa|slice(0,120) }}{% if q.feedbackIa|length > 120 %}…{% endif %}</p>
        </div>
        {% endif %}
        {% endfor %}

        {% if ressource.consolidatedAt %}
        <p class="text-xs text-white/25 mt-3">
            {{ 'ressource.consolidee_le'|trans({'%date%': ressource.consolidatedAt|date('d/m/Y')}) }}
        </p>
        {% endif %}
    </div>

    <div class="bg-[#6C63FF]/10 border border-[#6C63FF]/30 rounded-xl p-4 mb-4 flex items-center gap-3">
        <span class="text-xl">📅</span>
        <div>
            <p class="text-sm font-medium text-[#9b94ff]">{{ 'ressource.revision_planifiee'|trans }}</p>
            <a href="{{ path('app_revision_index') }}"
               class="text-xs text-[#6C63FF] hover:text-[#8b85ff] mt-0.5 inline-block transition">
                {{ 'ressource.voir_revisions'|trans }} →
            </a>
        </div>
    </div>
    {% endif %}

    <a href="{{ path('app_consolidation_initier', {'id': ressource.id}) }}"
       class="block w-full text-center text-sm text-white/40 hover:text-white/70 py-2 transition">
        {{ 'ressource.redo_consolidation'|trans }}
    </a>

    {% endif %}

</main>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
<script>
function pomodoro(ressourceId, pomodorosTotal) {
    return {
        ressourceId,
        pomodorosTotal,
        pomodoroActuel: 1,
        sousEtat: 'en_attente',
        secondes: 1500,
        timerInterval: null,
        notes: '',
        storageKey: 'pomodoro-ressource-' + ressourceId,
        notesKey: 'notes-ressource-' + ressourceId,

        init() {
            this.notes = localStorage.getItem(this.notesKey) || '';
            const saved = localStorage.getItem(this.storageKey);
            if (saved) {
                const data = JSON.parse(saved);
                this.sousEtat = data.sousEtat;
                this.pomodoroActuel = data.pomodoroActuel || 1;
                if (data.sousEtat === 'en_cours' || data.sousEtat === 'pause') {
                    const elapsed = Math.floor((Date.now() - data.startedAt) / 1000);
                    this.secondes = Math.max(0, data.secondesSaved - elapsed);
                    if (this.secondes > 0) {
                        this.lancerInterval();
                    } else {
                        this.finirPeriode();
                    }
                }
            }
            setInterval(() => this.sauvegarderNotes(), 5000);
        },

        demarrer() {
            this.sousEtat = 'en_cours';
            this.secondes = 1500;
            this.lancerInterval();
            this.sauvegarderEtat();
        },

        pause() {
            clearInterval(this.timerInterval);
            this.sousEtat = 'pause';
            this.secondes = 300;
            this.lancerInterval();
            this.sauvegarderEtat();
        },

        reprendre() {
            this.sousEtat = 'en_cours';
            this.secondes = 1500;
            this.lancerInterval();
            this.sauvegarderEtat();
        },

        arreter() {
            clearInterval(this.timerInterval);
            this.sousEtat = 'en_attente';
            this.secondes = 1500;
            localStorage.removeItem(this.storageKey);
        },

        lancerInterval() {
            clearInterval(this.timerInterval);
            this.timerInterval = setInterval(() => {
                this.secondes--;
                if (this.secondes % 10 === 0) this.sauvegarderEtat();
                if (this.secondes <= 0) {
                    clearInterval(this.timerInterval);
                    this.finirPeriode();
                }
            }, 1000);
        },

        finirPeriode() {
            if (this.sousEtat === 'en_cours') {
                if (this.pomodoroActuel >= this.pomodorosTotal) {
                    this.sousEtat = 'termine';
                    localStorage.removeItem(this.storageKey);
                } else {
                    this.pomodoroActuel++;
                    this.sousEtat = 'pause';
                    this.secondes = 300;
                    this.lancerInterval();
                    this.sauvegarderEtat();
                }
            } else if (this.sousEtat === 'pause') {
                this.sousEtat = 'en_cours';
                this.secondes = 1500;
                this.lancerInterval();
                this.sauvegarderEtat();
            }
        },

        sauvegarderEtat() {
            localStorage.setItem(this.storageKey, JSON.stringify({
                sousEtat: this.sousEtat,
                pomodoroActuel: this.pomodoroActuel,
                secondesSaved: this.secondes,
                startedAt: Date.now(),
            }));
        },

        sauvegarderNotes() {
            if (this.notes) localStorage.setItem(this.notesKey, this.notes);
        },

        affichageTemps() {
            const m = Math.floor(this.secondes / 60);
            const s = this.secondes % 60;
            return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
        },
    };
}
</script>
{% endblock %}
