{% extends 'base.html.twig' %}
{% block title %}{{ 'revision.index.title'|trans }}{% endblock %}
{% block body %}
<main class="p-4 max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">{{ 'revision.index.title'|trans }}</h1>
    {% for revision in revisions %}
    <div class="bg-white/5 rounded-xl p-4 mb-3 flex items-center justify-between">
        <div>
            <p class="font-medium">{{ revision.ressource.titre }}</p>
            <p class="text-sm text-white/40">{{ 'revision.iteration'|trans({'%n%': revision.iteration}) }} · {{ revision.datePrevue|date('d/m/Y') }}</p>
        </div>
        <form method="post" action="{{ path('app_revision_completer', {'id': revision.id}) }}" class="flex gap-2 items-center">
            <input type="hidden" name="_token" value="{{ csrf_token('revision-' ~ revision.id) }}">
            <select name="score" class="bg-white/10 text-white text-sm rounded px-2 py-1">
                {% for i in 1..5 %}<option value="{{ i }}">{{ i }}/5</option>{% endfor %}
            </select>
            <button type="submit" class="bg-[#6C63FF] text-white text-sm px-3 py-2 rounded-lg">{{ 'action.done'|trans }}</button>
        </form>
    </div>
    {% else %}
    <p class="text-white/40 text-center py-12">{{ 'revision.index.empty'|trans }}</p>
    {% endfor %}
</main>
{% endblock %}
