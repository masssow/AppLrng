# Copiez ce fichier en .env.local et renseignez les valeurs réelles
# Ce fichier ne doit JAMAIS être commité (.env.local est dans .gitignore)
#
# Générer APP_SECRET : php bin/console secret:generate-tokens
# ou : openssl rand -hex 32

APP_ENV=prod
APP_SECRET=REMPLACER_PAR_UNE_CHAINE_ALEATOIRE_32_CHARS

# MySQL / MariaDB — Hostinger
# Format : mysql://USER:PASSWORD@HOST:3306/DBNAME?serverVersion=8.0&charset=utf8mb4
# Pour MariaDB : ?serverVersion=10.6.21-MariaDB&charset=utf8mb4
DATABASE_URL="mysql://u123456789_acquisapp:MOT_DE_PASSE@127.0.0.1:3306/u123456789_acquisapp?serverVersion=8.0&charset=utf8mb4"

# Messenger — transport Doctrine (tables créées via doctrine:migrations:migrate)
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
MESSENGER_FAILED_TRANSPORT_DSN=doctrine://default?queue_name=failed&auto_setup=0

# IA — Groq (gratuit, modèle llama-3.3-70b-versatile)
# Récupérer sur https://console.groq.com
ANTHROPIC_API_KEY=gsk_VOTRE_CLE_GROQ_ICI

# URL de base (pour les emails et commandes CLI)
DEFAULT_URI=https://votre-domaine.com
