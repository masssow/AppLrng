{% extends 'base.html.twig' %}
{% block title %}{{ projet ? projet.titre : 'projet.none'|trans }}{% endblock %}
{% block body %}
<main class="p-4 max-w-2xl mx-auto pb-24">

    {% if projet is null %}
    <p class="text-white/40 text-center py-12">{{ 'projet.not_generated'|trans }}</p>
    {% else %}

    <a href="{{ path('app_parcours_show', {'id': projet.parcours.id}) }}"
       class="text-white/40 text-sm hover:text-white mb-4 inline-block transition">
        ← {{ projet.parcours.titre }}
    </a>

    <h1 class="text-2xl font-bold mb-2">{{ projet.titre }}</h1>
    <p class="text-white/50 mb-6">{{ projet.description }}</p>

    <div class="space-y-3">
        {% for etape in projet.microEtapes %}
        <div class="rounded-xl overflow-hidden
            {% if etape.statut.value == 'verrouillee' %}bg-white/3 opacity-50
            {% elseif etape.statut.value == 'complete' %}bg-green-900/20 border border-green-700/30
            {% else %}bg-white/5 border border-white/10{% endif %}">

            <div class="flex justify-between items-start p-4">
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                        {% if etape.statut.value == 'complete' %}<span class="text-green-400 text-sm">✓</span>
                        {% elseif etape.statut.value == 'verrouillee' %}<span class="text-white/30 text-sm">🔒</span>
                        {% elseif etape.statut.value == 'en_cours' %}<span class="text-blue-400 text-sm">▶</span>
                        {% else %}<span class="text-white/50 text-sm">○</span>{% endif %}
                        <p class="font-medium text-sm">{{ etape.ordre }}. {{ etape.titre }}</p>
                    </div>
                    <p class="text-xs text-white/40 ml-5">{{ ('type_etape.' ~ etape.type.value)|trans }} · {{ ('statut.' ~ etape.statut.value)|trans }}</p>
                    <p class="text-sm text-white/60 mt-2 ml-5">{{ etape.description }}</p>
                </div>
                <div class="flex gap-2 ml-3 shrink-0">
                    {% if etape.statut.value == 'disponible' %}
                    <form method="post" action="{{ path('app_projet_etape_demarrer', {'id': etape.id}) }}">
                        <button type="submit"
                            class="bg-white/10 hover:bg-white/20 text-white text-xs px-3 py-1.5 rounded-lg transition">
                            {{ 'action.start'|trans }}
                        </button>
                    </form>
                    {% elseif etape.statut.value == 'en_cours' %}
                    <a href="{{ path('app_projet_etape_rendu', {'id': etape.id}) }}"
                       class="bg-[#6C63FF] hover:bg-[#5a52e0] text-white text-xs px-3 py-1.5 rounded-lg transition">
                        {{ 'action.submit_rendu'|trans }}
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    {% endif %}
</main>
{% endblock %}
